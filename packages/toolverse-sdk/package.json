{
  "name": "@toolverse/sdk",
  "version": "0.1.0",
  "description": "Client-side SDK for integrating with the Toolverse platform",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/toolverse/toolverse",
    "directory": "packages/toolverse-sdk"
  },
  "keywords": [
    "toolverse",
    "sdk",
    "oauth",
    "billing"
  ]
}
