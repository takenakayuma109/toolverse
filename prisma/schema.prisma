generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ──────────────────────────────────────────────────────────────────────

enum UserRole {
  USER
  CREATOR
  ADMIN
}

enum ToolCategory {
  ai
  productivity
  finance
  marketing
  development
  creator
  automation
  analytics
  security
  healthcare
  education
  ecommerce
  communication
  iot
  media
  logistics
}

enum PricingType {
  free
  freemium
  paid
  subscription
}

enum BillingPeriod {
  monthly
  yearly
}

enum ToolStatus {
  DRAFT
  IN_REVIEW
  PUBLISHED
  REJECTED
}

enum ToolVisibility {
  PUBLIC
  UNLISTED
  PRIVATE
}

enum AuthMethod {
  NONE
  API_KEY
  OAUTH2
  JWT
}

enum CreatorTier {
  EARLY
  VERIFIED
  STANDARD
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum PayoutMethodType {
  stripe_connect
  bank_transfer
  paypal
}

enum UserBillingPlanStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
}

// ─── Auth Models (NextAuth compatible) ──────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String
  avatar         String?
  role           UserRole  @default(USER)
  hashedPassword String?
  emailVerified  DateTime?
  locale         String    @default("en") @db.VarChar(5)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  reviews        Review[]
  installedTools UserTool[]
  projects       Project[]
  creatorProfile CreatorProfile?
  payments       Payment[]
  subscriptions  Subscription[]
  billingPlans      UserBillingPlan[]
  activeUserEvents  ActiveUserEvent[]

  @@index([email])
  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core Models ────────────────────────────────────────────────────────────────

model Tool {
  id              String         @id @default(cuid())
  name            String
  slug            String         @unique
  description     String
  longDescription String?        @db.Text
  icon            String
  category        ToolCategory
  pricingType     PricingType    @default(free)
  price           Decimal?       @db.Decimal(10, 2)
  currency        String?        @default("USD") @db.VarChar(3)
  period          BillingPeriod?
  rating          Float          @default(0)
  reviewCount     Int            @default(0)
  userCount       Int            @default(0)
  isOfficial      Boolean        @default(false)
  isFeatured      Boolean        @default(false)
  isTrending      Boolean        @default(false)
  creatorId       String
  tags            String[]
  screenshots     String[]
  status          ToolStatus     @default(DRAFT)
  visibility      ToolVisibility @default(PUBLIC)
  serviceUrl      String?
  sandboxUrl      String?
  apiEndpoint     String?
  webhookUrl      String?
  authMethod      AuthMethod     @default(NONE)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  creator      CreatorProfile @relation(fields: [creatorId], references: [userId])
  reviews      Review[]
  installedBy  UserTool[]
  projectTools ProjectTool[]
  payments         Payment[]
  subscriptions    Subscription[]
  activeUserEvents ActiveUserEvent[]

  @@index([slug])
  @@index([category])
  @@index([creatorId])
  @@index([status, visibility])
  @@index([isFeatured])
  @@index([isTrending])
  @@index([rating])
}

model Review {
  id        String   @id @default(cuid())
  toolId    String
  userId    String
  rating    Int      @db.SmallInt
  comment   String   @db.Text
  createdAt DateTime @default(now())

  tool Tool @relation(fields: [toolId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([toolId, userId])
  @@index([toolId])
  @@index([userId])
}

model UserTool {
  userId      String
  toolId      String
  installedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  tool Tool @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@id([userId, toolId])
  @@index([userId])
  @@index([toolId])
}

// ─── Projects ───────────────────────────────────────────────────────────────────

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tools ProjectTool[]

  @@index([userId])
}

model ProjectTool {
  projectId String
  toolId    String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tool    Tool    @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@id([projectId, toolId])
  @@index([projectId])
  @@index([toolId])
}

// ─── Creator ────────────────────────────────────────────────────────────────────

model CreatorProfile {
  userId          String      @id
  displayName     String
  bio             String?     @db.Text
  website         String?
  tier            CreatorTier @default(STANDARD)
  stripeConnectId String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tools   Tool[]
  payouts Payout[]

  @@index([tier])
}

// ─── Payments & Billing ─────────────────────────────────────────────────────────

model Payment {
  id                    String        @id @default(cuid())
  userId                String
  toolId                String
  amount                Decimal       @db.Decimal(10, 2)
  currency              String        @default("USD") @db.VarChar(3)
  stripePaymentIntentId String?       @unique
  status                PaymentStatus @default(PENDING)
  createdAt             DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  tool Tool @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([toolId])
  @@index([status])
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String
  toolId               String
  stripeSubscriptionId String?            @unique
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  createdAt            DateTime           @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  tool Tool @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@unique([userId, toolId])
  @@index([userId])
  @@index([toolId])
  @@index([status])
}

model Payout {
  id              String          @id @default(cuid())
  creatorId       String
  amount          Decimal         @db.Decimal(10, 2)
  currency        String          @default("USD") @db.VarChar(3)
  method          PayoutMethodType
  status          PayoutStatus    @default(PENDING)
  stripeTransferId String?        @unique
  requestedAt     DateTime        @default(now())
  completedAt     DateTime?

  creator CreatorProfile @relation(fields: [creatorId], references: [userId], onDelete: Cascade)

  @@index([creatorId])
  @@index([status])
}

model BillingPlan {
  id            String        @id @default(cuid())
  name          String
  price         Decimal       @db.Decimal(10, 2)
  currency      String        @default("USD") @db.VarChar(3)
  period        BillingPeriod
  stripePriceId String?       @unique
  features      Json          @default("[]")
  mauLimit      Int?          // null = unlimited, e.g. 1000 for Free, 50000 for Pro
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  userPlans UserBillingPlan[]

  @@index([isActive])
}

model UserBillingPlan {
  id                   String                @id @default(cuid())
  userId               String
  planId               String
  stripeSubscriptionId String?               @unique
  status               UserBillingPlanStatus @default(ACTIVE)
  currentPeriodEnd     DateTime
  createdAt            DateTime              @default(now())

  user User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan BillingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([userId, planId])
  @@index([userId])
  @@index([planId])
  @@index([status])
}

// ─── Active User Tracking ───────────────────────────────────────────────────────

model ActiveUserEvent {
  id        String   @id @default(cuid())
  userId    String
  toolId    String
  creatorId String
  monthKey  String   @db.VarChar(7) // "YYYY-MM"
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  tool Tool @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@unique([userId, toolId, monthKey])
  @@index([creatorId, monthKey])
  @@index([toolId, monthKey])
}
